{
  "manifest_version": 3,
  "name": "magicPin",
  "version": "0.6.0",
  "description": "Save each device's pinned tabs to your Firefox Account and restore any device's set with one click.",
  "permissions": [
    "tabs",
    "storage",
    "cookies",
    "downloads"
  ],
  "background": {
    "scripts": [
      "src/background/main.js"
    ],
    "type": "module"
  },
  "action": {
    "default_title": "magicPin",
    "default_popup": "src/popup/popup.html",
    "default_icon": "icons/magicpin.svg"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "magicpin@michele-bono.github.io",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Alt+P"
      },
      "description": "Open the magicPin popup"
    }
  },
  "icons": {
    "16": "icons/magicpin.svg",
    "32": "icons/magicpin.svg",
    "48": "icons/magicpin.svg",
    "96": "icons/magicpin.svg",
    "128": "icons/magicpin.svg"
  },
  "homepage_url": "https://github.com/michele-bono/magicPin"
}
