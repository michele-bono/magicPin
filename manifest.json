{
  "manifest_version": 3,
  "name": "magicPin",
  "version": "0.3.0",
  "description": "Save each device's pinned tabs to your Firefox Account and restore any device's set with one click.",
  "permissions": [
    "tabs",
    "storage",
    "cookies"
  ],
  "background": {
    "scripts": [
      "src/background/main.js"
    ],
    "type": "module"
  },
  "action": {
    "default_title": "magicPin",
    "default_popup": "src/popup/popup.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "magicpin@voixstream.net",
      "strict_min_version": "115.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Alt+P"
      },
      "description": "Open the magicPin popup"
    }
  }
}
