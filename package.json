{
  "name": "magicpin",
  "version": "0.6.0",
  "description": "Firefox extension: each device's pinned tabs saved to your Firefox Account \u2014 restore, merge, or snapshot any device's set in one click.",
  "author": "Michele Bono",
  "license": "MIT",
  "private": true,
  "homepage": "https://github.com/michele-bono/magicPin#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/michele-bono/magicPin.git"
  },
  "bugs": {
    "url": "https://github.com/michele-bono/magicPin/issues"
  },
  "keywords": [
    "firefox",
    "webextension",
    "pinned-tabs",
    "sync",
    "firefox-sync",
    "containers"
  ],
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "lint": "web-ext lint",
    "start": "web-ext run"
  },
  "devDependencies": {
    "vitest": "^3.0.0",
    "web-ext": "^8.0.0"
  },
  "webExt": {
    "sourceDir": ".",
    "ignoreFiles": [
      "tests/**",
      "docs/**",
      "package.json",
      "package-lock.json",
      ".gitignore",
      "README.md"
    ]
  }
}
